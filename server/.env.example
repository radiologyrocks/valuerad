# Copy to .env and fill in your values before starting the server
PORT=3001

# Epic App Gallery client ID (from your app registration)
EPIC_CLIENT_ID=your-epic-client-id

# Leave blank for public (PKCE-only) apps; set for confidential apps
EPIC_CLIENT_SECRET=

# Must exactly match the redirect URI registered in Epic App Gallery
EPIC_REDIRECT_URI=https://valuerad.yourdomain.com/epic/callback
