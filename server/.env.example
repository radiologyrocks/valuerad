# Copy to .env and fill in your values before starting the server
PORT=3001

# ---------------------------------------------------------------------------
# Epic SMART App Launch (existing)
# ---------------------------------------------------------------------------
# Epic App Gallery client ID (from your app registration)
EPIC_CLIENT_ID=your-epic-client-id

# Leave blank for public (PKCE-only) apps; set for confidential apps
EPIC_CLIENT_SECRET=

# Must exactly match the redirect URI registered in Epic App Gallery
EPIC_REDIRECT_URI=https://valuerad.yourdomain.com/epic/callback

# FHIR identifier system Epic assigns to radiology accession numbers. Used to
# resolve a billing exception's accession to an Epic DiagnosticReport/ImagingStudy.
# Leave blank to search by bare accession value. Confirm the system with your
# Epic/interface team (varies by site).
ACCESSION_IDENTIFIER_SYSTEM=

# ---------------------------------------------------------------------------
# MBMS billing-exception feed
# ---------------------------------------------------------------------------
# "mock" (default) runs against built-in seed data; "api" talks to MBMS.
MBMS_SOURCE=mock
MBMS_API_BASE_URL=
MBMS_API_KEY=
# Header to send the key on: "Authorization" (Bearer) or e.g. "X-API-Key".
MBMS_AUTH_HEADER=Authorization

# ---------------------------------------------------------------------------
# PowerScribe (Nuance) reporting integration
# ---------------------------------------------------------------------------
# "mock" (default) runs against built-in sample reports; "api" talks to PowerScribe.
POWERSCRIBE_SOURCE=mock
POWERSCRIBE_API_BASE_URL=
POWERSCRIBE_API_KEY=
# How the front-end opens a study in PowerScribe. Provide ONE of:
#   POWERSCRIBE_LAUNCH_SCHEME — custom URI scheme, accession appended
#     e.g. powerscribe://open?accession=
#   POWERSCRIBE_LAUNCH_URL — site launch endpoint; ?accession= is appended
POWERSCRIBE_LAUNCH_SCHEME=
POWERSCRIBE_LAUNCH_URL=

# ---------------------------------------------------------------------------
# Claude (addendum drafting)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
# Optional model override (defaults to claude-opus-4-8)
ADDENDUM_MODEL=claude-opus-4-8
