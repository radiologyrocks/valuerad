# Copy to .env and fill in your values before starting the server
PORT=3001

# --- Epic / SMART on FHIR ---
# Epic App Gallery client ID (from your app registration)
EPIC_CLIENT_ID=your-epic-client-id

# Leave blank for public (PKCE-only) apps; set for confidential apps
EPIC_CLIENT_SECRET=

# Must exactly match the redirect URI registered in Epic App Gallery
EPIC_REDIRECT_URI=https://valuerad.yourdomain.com/epic/callback

# --- Durable system of record (Stage 0) ---
# Postgres connection string. If unset, the server uses a NON-DURABLE in-memory
# store (dev only). Required in production.
DATABASE_URL=postgres://user:pass@host:5432/valuerad
# Set to "disable" only for local Postgres without TLS.
# PGSSL=disable

# --- Token encryption at rest (Stage 0) ---
# 32 random bytes, base64-encoded. Required in production.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENC_KEY=

# --- Command-center agent (Stages 3-4) ---
# Anthropic API key. Without it, POST /api/agent/run returns 503.
# Required before any PHI reaches the model — sign a BAA with the provider first.
ANTHROPIC_API_KEY=
# Optional model override (defaults to claude-opus-4-8).
# AGENT_MODEL=claude-opus-4-8

# --- Runtime ---
# Set to "production" to enforce DATABASE_URL + TOKEN_ENC_KEY at startup.
NODE_ENV=development
